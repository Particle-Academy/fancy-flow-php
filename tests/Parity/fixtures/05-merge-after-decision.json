{
    "name": "05-merge-after-decision",
    "description": "A decision routes down one branch; the merge point still runs (#1).",
    "schema": {
        "$schema": "https://particle.academy/schemas/workflow/v1.json",
        "version": 1,
        "graph": {
            "nodes": [
                {
                    "id": "t",
                    "kind": "manual_trigger",
                    "position": {
                        "x": 0,
                        "y": 0
                    }
                },
                {
                    "id": "br",
                    "kind": "branch",
                    "position": {
                        "x": 1,
                        "y": 0
                    },
                    "config": {
                        "condition": "{{ $json.ok }}"
                    }
                },
                {
                    "id": "a",
                    "kind": "transform",
                    "position": {
                        "x": 2,
                        "y": 0
                    },
                    "config": {
                        "expression": "A"
                    }
                },
                {
                    "id": "b",
                    "kind": "transform",
                    "position": {
                        "x": 2,
                        "y": 1
                    },
                    "config": {
                        "expression": "B"
                    }
                },
                {
                    "id": "m",
                    "kind": "merge",
                    "position": {
                        "x": 3,
                        "y": 0
                    },
                    "config": {
                        "mode": "merge"
                    }
                },
                {
                    "id": "o",
                    "kind": "output",
                    "position": {
                        "x": 4,
                        "y": 0
                    }
                }
            ],
            "edges": [
                {
                    "id": "e1",
                    "source": "t",
                    "target": "br"
                },
                {
                    "id": "e2",
                    "source": "br",
                    "target": "a",
                    "sourceHandle": "true"
                },
                {
                    "id": "e3",
                    "source": "br",
                    "target": "b",
                    "sourceHandle": "false"
                },
                {
                    "id": "e4",
                    "source": "a",
                    "target": "m",
                    "targetHandle": "a"
                },
                {
                    "id": "e5",
                    "source": "b",
                    "target": "m",
                    "targetHandle": "b"
                },
                {
                    "id": "e6",
                    "source": "m",
                    "target": "o"
                }
            ]
        }
    },
    "initialInputs": {
        "t": {
            "ok": true
        }
    },
    "expected": {
        "ok": true,
        "outputs": {
            "t": {
                "ok": true
            },
            "br": {
                "branch": "true",
                "value": {
                    "ok": true
                }
            },
            "a": "A",
            "m": {
                "a": "A"
            },
            "o": {
                "a": "A"
            }
        }
    }
}
